DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/heat_backend
SQLALCHEMY_ECHO=false
AUTO_CREATE_SCHEMA=true
DISTRICT_CACHE_TTL_SECONDS=300

# Placeholders for future authenticated data access.
CDSAPI_URL=https://cds.climate.copernicus.eu/api
CDSAPI_KEY=<your-cds-api-key>

# Optional IMD ingestion paths.
IMD_METADATA_JSON=/data/imd/config.json
IMD_BINARY_DIR=/data/imd/binaries
